# 服务器配置
# 服务器监听地址
HOST=0.0.0.0
# 服务器监听端口
PORT=3000
# 资源文件根目录
RESOURCES=./resources

# 防盗链配置
# 是否允许空的Referer头
ALLOW_EMPTY_REFERER=true
# 允许的Referer白名单
REFERERS=http://localhost:3000

# 资源库配置
# 资源库标识名称
STORAGE_NAME=本地

# 跨域配置
# 允许跨域访问的域名
CORS_ORIGIN=http://localhost:3000

# 速率限制配置
# 时间窗口(分钟)
RATE_LIMIT_WINDOW=15
# 每窗口最大请求数
RATE_LIMIT_MAX=100

# 日志配置
# 日志级别：error/warn/info/debug
LOG_LEVEL=info
# 环境：production/development
NODE_ENV=production

# 映射到宿主机的端口
DOCKER_PORT=3000

# 宿主机的资源目录路径
DOCKER_RESOURCES=./resources